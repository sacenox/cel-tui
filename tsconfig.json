{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["@types/bun"],
    "paths": {
      "@cel-tui/types": ["./packages/types/src/index.ts"],
      "@cel-tui/core": ["./packages/core/src/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*.ts"]
}
