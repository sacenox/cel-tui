{
  "name": "cel-tui",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "biome check packages/*/src/**/*.ts",
    "check:fix": "biome check --write packages/*/src/**/*.ts",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "get-east-asian-width": "^1.5.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  }
}
